<!-- MainWindow.xaml -->
<Window x:Class="WinQuickTools.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
		xmlns:local="clr-namespace:WinQuickTools"
        Title="WinQuickTools"
        Width="520"
        Height="440"
        MinWidth="420"
        MinHeight="320"
        Background="#1e1e1e"
        WindowStyle="None"
        ResizeMode="CanResize">

	<shell:WindowChrome.WindowChrome>
		<shell:WindowChrome CaptionHeight="32"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"/>
	</shell:WindowChrome.WindowChrome>

	
	
	<Window.Resources>

		<local:BoolToStarConverter x:Key="BoolToStarConverter"/>

		<!-- 공통 버튼(타일): 즐겨찾기 별표 포함 -->
		<Style x:Key="TileButtonStyle" TargetType="Button">
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="Background" Value="Black"/>
			<Setter Property="BorderBrush" Value="White"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="10,8"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
							<Grid>
								<ContentPresenter HorizontalAlignment="Stretch"
												  VerticalAlignment="Stretch"/>
							</Grid>
						</Border>

						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="border" Property="Background" Value="White"/>
								<Setter Property="Foreground" Value="Black"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter TargetName="border" Property="Background" Value="#DDDDDD"/>
								<Setter Property="Foreground" Value="Black"/>
							</Trigger>
							<Trigger Property="IsEnabled" Value="False">
								<Setter TargetName="border" Property="Opacity" Value="0.45"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>



		<!-- 닫기 버튼 -->
		<Style x:Key="CloseButtonStyle" TargetType="Button">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="Transparent">
							<TextBlock Text="✕"
                                       FontSize="14"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Foreground" Value="#BBBBBB"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- 링크형 행 -->
		<Style x:Key="LinkRowButtonStyle" TargetType="Button">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Foreground" Value="#BBBBBB"/>
			<Setter Property="Padding" Value="0"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="Transparent" Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Foreground" Value="White"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- 얇은 스크롤바 -->
		<Style x:Key="ThinScrollBar" TargetType="{x:Type ScrollBar}">
			<Setter Property="Width" Value="2"/>
			<Setter Property="MinWidth" Value="2"/>
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="{x:Type ScrollBar}">
						<Grid Background="Transparent"
                              Width="{TemplateBinding Width}"
                              SnapsToDevicePixels="True"
                              UseLayoutRounding="True">
							<Track x:Name="PART_Track"
       Orientation="{TemplateBinding Orientation}"
       IsDirectionReversed="True"
       SnapsToDevicePixels="True">
								<Track.DecreaseRepeatButton>
									<RepeatButton Opacity="0" IsHitTestVisible="False"/>
								</Track.DecreaseRepeatButton>
								<Track.IncreaseRepeatButton>
									<RepeatButton Opacity="0" IsHitTestVisible="False"/>
								</Track.IncreaseRepeatButton>
								<Track.Thumb>
									<Thumb>
										<Thumb.Template>
											<ControlTemplate TargetType="{x:Type Thumb}">
												<Border x:Name="thumb"
                                                        Background="#666"
                                                        CornerRadius="2"
                                                        SnapsToDevicePixels="True"
                                                        UseLayoutRounding="True"/>
												<ControlTemplate.Triggers>
													<Trigger Property="IsMouseOver" Value="True">
														<Setter TargetName="thumb" Property="Background" Value="#AAA"/>
													</Trigger>
													<Trigger Property="IsDragging" Value="True">
														<Setter TargetName="thumb" Property="Background" Value="#BBB"/>
													</Trigger>
												</ControlTemplate.Triggers>
											</ControlTemplate>
										</Thumb.Template>
									</Thumb>
								</Track.Thumb>
							</Track>
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<DataTemplate x:Key="FeatureTileTemplate">
			<Button Margin="4"
					MinHeight="72"
					Style="{StaticResource TileButtonStyle}"
					Click="Feature_Click"
					Tag="{Binding Id}">

				<!-- 카드 전체 기준 -->
				<Grid>

					<!-- 내용 -->
					<StackPanel HorizontalAlignment="Center"
								VerticalAlignment="Center">
						<TextBlock Text="{Binding Title}"
								   FontSize="14"
								   HorizontalAlignment="Center"/>

						<TextBlock Text="{Binding StatusText}"
								   FontSize="12"
								   Foreground="#9A9A9A"
								   HorizontalAlignment="Center"/>

						<TextBlock Text="{Binding SubTitle}"
								   FontSize="11"
								   Foreground="#9A9A9A"
								   HorizontalAlignment="Center"/>
					</StackPanel>

					<!-- ⭐ 카드 우상단 고정 -->
					<Button Width="24"
							Height="24"
							HorizontalAlignment="Right"
							VerticalAlignment="Top"
							Margin="0,6,8,0"
							Click="ToggleFavorite_Click"
							Tag="{Binding Id}"
							Focusable="False"
							Background="Transparent"
							BorderThickness="0"
							OverridesDefaultStyle="True">

						<Button.Template>
							<ControlTemplate TargetType="Button">
								<Border Background="Transparent">
									<TextBlock x:Name="star"
											   Text="{Binding IsFavorite,
                                          Converter={StaticResource BoolToStarConverter}}"
											   FontSize="14"
											   Foreground="#888"
											   HorizontalAlignment="Center"
											   VerticalAlignment="Center"/>
								</Border>

								<ControlTemplate.Triggers>
									<!-- ⭐만 hover -->
									<Trigger Property="IsMouseOver" Value="True">
										<Setter TargetName="star"
												Property="Foreground"
												Value="Gold"/>
									</Trigger>

									<Trigger Property="IsPressed" Value="True">
										<Setter TargetName="star"
												Property="RenderTransform">
											<Setter.Value>
												<ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
											</Setter.Value>
										</Setter>
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Button.Template>

					</Button>

				</Grid>
			</Button>
		</DataTemplate>
	</Window.Resources>

	<Border BorderBrush="#3a3a3a"
            BorderThickness="1"
            Background="#1e1e1e">

		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="32"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			
			<!-- 타이틀바 -->
			<!-- 타이틀바 -->
			<Border Grid.Row="0"
					Background="#1e1e1e"
					MouseLeftButtonDown="DragWindow">

				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition/>
						<ColumnDefinition Width="40"/>
						<ColumnDefinition Width="40"/>
						<ColumnDefinition Width="40"/>
					</Grid.ColumnDefinitions>

					<!-- 제목 -->
					<TextBlock Grid.Column="0"
           Text="WinQuickTools"
           Foreground="White"
           VerticalAlignment="Center"
           Margin="12,0,0,0"
           FontSize="14"/>

					<!-- ⚙ 설정 버튼 -->
					<Button Width="40"
							Height="32"
							HorizontalAlignment="Stretch"
							Click="OpenSettings_Click"
							Background="Transparent"
							BorderThickness="0"
							shell:WindowChrome.IsHitTestVisibleInChrome="True"
							Grid.Column="1">

						<Button.Template>
							<ControlTemplate TargetType="Button">
								<Border Background="Transparent">
									<Viewbox Width="18" Height="18">
										<Canvas Width="24" Height="24">

											<Path x:Name="gear"
												  Data="M9.671 4.136a2.34 2.34 0 0 1 4.659 0 2.34 2.34 0 0 0 3.319 1.915 2.34 2.34 0 0 1 2.33 4.033 2.34 2.34 0 0 0 0 3.831 2.34 2.34 0 0 1-2.33 4.033 2.34 2.34 0 0 0-3.319 1.915 2.34 2.34 0 0 1-4.659 0 2.34 2.34 0 0 0-3.32-1.915 2.34 2.34 0 0 1-2.33-4.033 2.34 2.34 0 0 0 0-3.831A2.34 2.34 0 0 1 6.35 6.051a2.34 2.34 0 0 0 3.319-1.915"
												  Stroke="White"
												  StrokeThickness="2"
												  StrokeStartLineCap="Round"
												  StrokeEndLineCap="Round"
												  StrokeLineJoin="Round"
												  Fill="Transparent"/>

											<Ellipse x:Name="gearCenter"
													 Canvas.Left="9"
													 Canvas.Top="9"
													 Width="6"
													 Height="6"
													 Stroke="White"
													 StrokeThickness="2"
													 Fill="Transparent"/>

										</Canvas>
									</Viewbox>
								</Border>

								<ControlTemplate.Triggers>

									<!-- hover = 색만 변경 -->
									<Trigger Property="IsMouseOver" Value="True">
										<Setter TargetName="gear" Property="Stroke" Value="#BBBBBB"/>
										<Setter TargetName="gearCenter" Property="Stroke" Value="#BBBBBB"/>
									</Trigger>

								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Button.Template>

					</Button>
					
					
					<!-- 최소화 버튼 -->
					<Button Width="40"
							Height="32"
							HorizontalAlignment="Stretch"
							Click="Minimize_Click"
							Background="Transparent"
							BorderThickness="0"
							shell:WindowChrome.IsHitTestVisibleInChrome="True"
							Grid.Column="2">

						<Button.Template>
							<ControlTemplate TargetType="Button">
								<Border Background="Transparent">

									<Viewbox Width="14" Height="14">
										<Canvas Width="24" Height="24">

											<Line x:Name="minLine"
												  X1="5" Y1="12"
												  X2="19" Y2="12"
												  Stroke="White"
												  StrokeThickness="2"
												  StrokeStartLineCap="Round"
												  StrokeEndLineCap="Round"/>

										</Canvas>
									</Viewbox>

								</Border>

								<ControlTemplate.Triggers>
									<Trigger Property="IsMouseOver" Value="True">
										<Setter TargetName="minLine"
												Property="Stroke"
												Value="#BBBBBB"/>
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Button.Template>

					</Button>
					

					<!-- 닫기 버튼 -->
					<Button Width="40"
							Height="32"
							HorizontalAlignment="Stretch"
							Background="Transparent"
							BorderThickness="0"
							Padding="0"
							Click="Close_Click"
							Style="{StaticResource CloseButtonStyle}"
							shell:WindowChrome.IsHitTestVisibleInChrome="True"
							Grid.Column="3"/>

				</Grid>
			</Border>

			<!-- 본문 -->
			<ScrollViewer x:Name="MainScroll"
    Grid.Row="1"
    VerticalScrollBarVisibility="Visible"
    HorizontalScrollBarVisibility="Disabled"
    CanContentScroll="False"
    SnapsToDevicePixels="True"
    PanningMode="VerticalOnly"
    Padding="16,16,16,16">

				<!-- 이 ScrollViewer에만 스크롤바 스타일 적용 -->
				<ScrollViewer.Resources>
					<Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ThinScrollBar}"/>
				</ScrollViewer.Resources>
				<StackPanel>

					<!-- ============================= -->
					<!-- 즐겨찾기 -->
					<!-- ============================= -->

					<TextBlock Text="즐겨찾기"
							   Foreground="White"
							   FontSize="14"
							   Margin="0,0,0,10"/>

					<TextBlock x:Name="StatusText"
							   Foreground="#9A9A9A"
							   FontSize="12"
							   Margin="0,0,0,12"/>

					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition/>
							<RowDefinition/>
							<RowDefinition/>
						</Grid.RowDefinitions>
						<Grid.ColumnDefinitions>
							<ColumnDefinition/>
							<ColumnDefinition/>
						</Grid.ColumnDefinitions>

						<ContentControl Grid.Row="0" Grid.Column="0"
										Content="{Binding FavoriteSlots[0]}"
										ContentTemplate="{StaticResource FeatureTileTemplate}"/>

						<ContentControl Grid.Row="0" Grid.Column="1"
										Content="{Binding FavoriteSlots[1]}"
										ContentTemplate="{StaticResource FeatureTileTemplate}"/>

						<ContentControl Grid.Row="1" Grid.Column="0"
										Content="{Binding FavoriteSlots[2]}"
										ContentTemplate="{StaticResource FeatureTileTemplate}"/>

						<ContentControl Grid.Row="1" Grid.Column="1"
										Content="{Binding FavoriteSlots[3]}"
										ContentTemplate="{StaticResource FeatureTileTemplate}"/>

						<ContentControl Grid.Row="2" Grid.Column="0"
										Content="{Binding FavoriteSlots[4]}"
										ContentTemplate="{StaticResource FeatureTileTemplate}"/>

						<ContentControl Grid.Row="2" Grid.Column="1"
										Content="{Binding FavoriteSlots[5]}"
										ContentTemplate="{StaticResource FeatureTileTemplate}"/>
					</Grid>


					<!-- ============================= -->
					<!-- 전체 기능 -->
					<!-- ============================= -->

					<TextBlock Text="전체 기능"
							   Foreground="White"
							   FontSize="14"
							   Margin="0,18,0,8"/>

					<ItemsControl ItemsSource="{Binding NonFavoriteItems}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<UniformGrid Columns="2"/>
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>

						<ItemsControl.ItemTemplate>
							<StaticResource ResourceKey="FeatureTileTemplate"/>
						</ItemsControl.ItemTemplate>
					</ItemsControl>


					<!-- ============================= -->
					<!-- ⭐ 우클릭 기능 (NEW) -->
					<!-- ============================= -->

					<TextBlock Text="우클릭 기능"
							   Foreground="White"
							   FontSize="14"
							   Margin="0,18,0,8"/>

					<TextBlock Text="탐색기 shfit + 우클릭 메뉴에 추가되는 기능"
							   Foreground="#9A9A9A"
							   FontSize="11"
							   Margin="0,0,0,10"/>

					<ItemsControl ItemsSource="{Binding RightClickItems}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<UniformGrid Columns="2"/>
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>

						<ItemsControl.ItemTemplate>
							<StaticResource ResourceKey="FeatureTileTemplate"/>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
				
				
			</ScrollViewer>
		</Grid>
	</Border>
</Window>