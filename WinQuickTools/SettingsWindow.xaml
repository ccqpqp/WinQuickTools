<Window x:Class="WinQuickTools.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="설정"
        Width="380"
        Height="280"
        Background="#111111"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None"
        ResizeMode="NoResize">

	<shell:WindowChrome.WindowChrome>
		<shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="0"
                            CornerRadius="12"
                            GlassFrameThickness="0"/>
	</shell:WindowChrome.WindowChrome>

	<Window.Resources>
		<Style TargetType="Button">
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="Background" Value="#222222"/>
			<Setter Property="BorderBrush" Value="#333333"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="12,10"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
								<Setter TargetName="Bd" Property="BorderBrush" Value="#4A4A4A"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter TargetName="Bd" Property="Background" Value="#333333"/>
							</Trigger>
							<Trigger Property="IsEnabled" Value="False">
								<Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
			<Setter Property="Background" Value="#3A1F1F"/>
			<Setter Property="BorderBrush" Value="#5A2A2A"/>
		</Style>

		<Style TargetType="CheckBox">
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="CheckBox">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>

							<!-- 토글 -->
							<Border x:Name="Track"
                                    Width="44" Height="24"
                                    CornerRadius="12"
                                    Background="#2A2A2A"
                                    BorderBrush="#3A3A3A"
                                    BorderThickness="1">
								<Grid>
									<Ellipse x:Name="Thumb"
                                             Width="18" Height="18"
                                             Fill="#BDBDBD"
                                             Margin="3"
                                             HorizontalAlignment="Left"/>
								</Grid>
							</Border>

							<StackPanel Grid.Column="1" Margin="12,0,0,0">
								<ContentPresenter/>
								<TextBlock Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                           Foreground="#9A9A9A"
                                           FontSize="11"
                                           Margin="0,4,0,0"/>
							</StackPanel>
						</Grid>

						<ControlTemplate.Triggers>
							<Trigger Property="IsChecked" Value="True">
								<Setter TargetName="Track" Property="Background" Value="#1F3A2A"/>
								<Setter TargetName="Track" Property="BorderBrush" Value="#2F5A3E"/>
								<Setter TargetName="Thumb" Property="Fill" Value="#E6FFE9"/>
								<Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</Window.Resources>

	<Border CornerRadius="12" Background="#151515" BorderBrush="#2A2A2A" BorderThickness="1">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="40"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<!-- Header -->
			<Border Grid.Row="0"
                    Background="#151515"
                    MouseLeftButtonDown="DragWindow">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition/>
						<ColumnDefinition Width="40"/>
					</Grid.ColumnDefinitions>

					<TextBlock Text="설정"
                               Foreground="White"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="14,0,0,0"/>

					<Button Grid.Column="1"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#CFCFCF"
                            FontSize="14"
                            Content="✕"
                            Click="Close_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
				</Grid>
			</Border>

			<!-- Body -->
			<StackPanel Grid.Row="1" Margin="18">
				<Border Background="#1B1B1B" CornerRadius="12" BorderBrush="#2A2A2A" BorderThickness="1" Padding="14">
					<StackPanel>
						<CheckBox x:Name="AutoStartCheck"
                                  Content="윈도우 시작 시 자동 실행"
                                  Tag="로그인 후 자동으로 실행됩니다."
                                  Checked="AutoStart_Checked"
                                  Unchecked="AutoStart_Unchecked"/>

						<Border Height="1" Background="#2A2A2A" Margin="0,14,0,14"/>

						<TextBlock Text="초기화"
                                   Foreground="White"
                                   FontSize="13"
                                   Margin="0,0,0,10"/>

						<Button Content="설정 전체 초기화"
                                Style="{StaticResource DangerButton}"
                                Click="ResetAll_Click"/>
						<TextBlock Text="확장자/숨김파일/클립보드/우클릭 메뉴 등 설정을 초기 상태로 되돌립니다."
                                   Foreground="#9A9A9A"
                                   FontSize="11"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"/>
					</StackPanel>
				</Border>

				<TextBlock x:Name="HintText"
                           Foreground="#7A7A7A"
                           FontSize="11"
                           Margin="4,10,0,0"
                           Text=""/>
			</StackPanel>
		</Grid>
	</Border>
</Window>